# theme/styling
theme = Rose Pine Moon
palette-generate = true
font-family = Fira Code

# window appearance
window-colorspace = display-p3
background-opacity = 0.95
background-blur = true
macos-titlebar-style = tabs

# system integration
shell-integration-features = cursor,sudo,title,ssh-terminfo,ssh-env
bell-features = no-attention,no-system,title,border
notify-on-command-finish = unfocused
notify-on-command-finish-action = bell,notify
notify-on-command-finish-after = 30s

# working directory
window-inherit-working-directory = false
tab-inherit-working-directory = true
split-inherit-working-directory = true

# terminal interaction
link-url = true
link-previews = true
clipboard-read = ask
copy-on-select = true

# input
mouse-scroll-multiplier = precision:1,discrete:0.5
macos-option-as-alt = right

# keybinds
## term control
keybind = super+shift+k=clear_screen
keybind = super+shift+r=reset
keybind = chain=clear_screen
keybind = chain=text:\x03
## windows
keybind = super+alt+[=goto_window:previous
keybind = super+alt+]=goto_window:next
## tabs
keybind = super+;=move_tab:-1
keybind = super+'=move_tab:1
keybind = super+shift+[=previous_tab
keybind = super+shift+]=next_tab
keybind = ctrl+tab=unbind
keybind = ctrl+shift+tab=unbind
## splits
keybind = super+[=goto_split:previous
keybind = super+]=goto_split:next
keybind = super+h=goto_split:left
keybind = super+j=goto_split:down
keybind = super+k=goto_split:up
keybind = super+l=goto_split:right
keybind = super+alt+arrow_down=unbind
keybind = super+alt+arrow_left=unbind
keybind = super+alt+arrow_right=unbind
keybind = super+alt+arrow_up=unbind
keybind = super+ctrl+arrow_down=unbind
keybind = super+ctrl+arrow_left=unbind
keybind = super+ctrl+arrow_right=unbind
keybind = super+ctrl+arrow_up=unbind
## prompts
keybind = super+shift+j=jump_to_prompt:-1
keybind = super+shift+k=jump_to_prompt:1
keybind = super+shift+arrow_down=unbind
keybind = super+shift+arrow_up=unbind
